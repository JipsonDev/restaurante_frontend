{
  "expo": {
    "name": "Morena Mia POS",
    "slug": "mi-restaurante",
    "version": "1.0.0",
    "description": "Sistema POS para restaurante con administracion, meseros, cocina y caja.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#F6F8FB",
    "primaryColor": "#0F172A",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.anonymous.mirestaurante"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications"
    ]
  }
}
